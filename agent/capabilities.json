{
  "version": 1,
  "hard_rules": [
    "禁止外部工具创建或连接第二个 Appium session 进行 UI 变更操作",
    "输入必须走 console/queue（例如在控制台输入 :command 或后台管理命令）",
    "复用已运行进程时，后台注入必须写入 .agent/commands/*.cmd 并由主程序汇入同一条 console/queue 路径",
    "UI 只读证据（page_source/screenshot）必须由主程序现有 session 导出并落盘，外部仅读取文件"
  ],
  "capabilities": [
    {
      "id": "read.artifacts.status_json",
      "can": true,
      "requires": ["artifacts/<run_id>/status.json exists"],
      "outputs": ["parsed_state"]
    },
    {
      "id": "read.artifacts.events_jsonl",
      "can": true,
      "requires": ["artifacts/<run_id>/events.jsonl exists"],
      "outputs": ["event_stream"]
    },
    {
      "id": "inject.console.queue_command",
      "can": true,
      "requires": ["service_running"],
      "outputs": ["queue.enqueue event"]
    },
    {
      "id": "inject.agent_spool.queue_command",
      "can": true,
      "requires": ["service_running", ".agent/commands is writable"],
      "outputs": ["agent.inject.received event", "queue.enqueue event"]
    },
    {
      "id": "run.agent_e2e.auto",
      "can": true,
      "requires": ["unit_or_script_tests_passed", "e2e_risk_present"],
      "outputs": ["agent_e2e_report.md"]
    },
    {
      "id": "run.agent_e2e.manual",
      "can": true,
      "requires": ["user_requested_runtime_test"],
      "outputs": ["agent_e2e_report.md"]
    },
    {
      "id": "appium.ui.mutate",
      "can": false,
      "reason": "会与主程序已存在的 Appium session 冲突"
    }
  ]
}
