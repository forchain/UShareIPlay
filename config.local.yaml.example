# config.local.yaml.example
#
# 本地环境配置示例。将此文件复制为 config.local.yaml 并按需修改。
# config.local.yaml 不纳入版本控制，可安全存放本地差异配置。
#
# 规则：只需填写与 config.yaml 不同的字段，其余保持默认值。
# 嵌套 dict 支持局部覆盖；列表字段会整体替换。

# 设备连接地址（开发机与生产机通常不同）
device:
  name: "192.168.x.x:5555"   # 替换为你的设备地址或 ADB 序列号

# Appium 服务器地址（本地调试时指向 localhost）
appium:
  host: "localhost"
  port: 4723

# E2E 远程协同。实际值写入 config.local.yaml（该文件已忽略）。
# host 可为 SSH config alias，也可为 user@host；部署方式和日志路径由 toolbelt 自动发现。
agent_e2e:
  remote:
    host: "tony@192.168.8.103"
    deploy_path: "~/github.com/forchain/UShareIPlay"

# Soul App 派对 ID（开发环境使用测试派对）
soul:
  default_party_id: "FM00000000"   # 替换为你的测试派对 ID
  # 可选：本机桌面/启动器包名（用于事件循环判定是否回到 Soul）
  # launcher_packages:
  #   - "com.miui.home"
